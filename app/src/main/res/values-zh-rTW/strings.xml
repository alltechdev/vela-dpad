    <string name="settings_saved_places">已儲存的地點</string>
    <string name="settings_saved_places_hint">將加星號的地點備份到檔案，或在另一部裝置上還原。匯入會與現有內容合併，絕不會覆寫或移除任何資料。</string>
    <string name="settings_import_nothing">沒有新內容可匯入</string>
    <string name="settings_no_saved_places">尚未儲存任何地點</string>
    <string name="settings_export">匯出</string>
    <string name="settings_import">匯入</string>
    <string name="settings_data_privacy">資料來源與隱私權</string>
    <string name="settings_data_privacy_hint">Vela 直接從這部裝置存取 Google 的公開端點：沒有後端伺服器、不需帳戶、沒有 API 金鑰。Google 只會看到你的 IP、查詢內容和地圖範圍，不會知道你是誰。</string>
    <string name="settings_privacy_button">Google 會收到哪些資料</string>
    <string name="settings_diagnostics">診斷</string>
    <string name="settings_diagnostics_hint">預設為關閉。開啟後，Vela 會在本機保留簡短記錄，可匯出交給開發者。不會上傳任何內容，關閉時會清除記錄。</string>
    <string name="settings_share_diagnostics">分享診斷資料</string>
    <string name="settings_diag_nothing">尚無任何記錄。請先使用應用程式，再匯出。</string>
    <string name="settings_diag_export">匯出偵錯工作階段</string>
    <string name="settings_save_trips">儲存我的行程（供重播）</string>
    <string name="settings_save_trips_hint">在這支手機上記錄每次行駛的 GPS 軌跡，之後可以重播。資料絕不會離開手機。</string>
    <string name="settings_recorded_trips_hint">已記錄的行程。點按「重播」即可在地圖上以 3 倍速回放：</string>
    <string name="settings_trip_points">%1$d 個定位點</string> <!-- format -->
    <string name="settings_trip_replay">重播</string>
    <string name="settings_trip_read_error">無法讀取這筆行程</string>
    <string name="settings_trip_share">分享</string>
    <string name="settings_trip_delete">刪除行程</string>
    <string name="settings_no_trips_hint">尚未記錄任何行程。開啟這項功能後導航到某個地方，行程就會出現在這裡供重播。</string>
    <string name="settings_trip_consent_title">要儲存你的行程嗎？</string>
    <string name="settings_trip_consent_body">Vela 會在這支手機上記錄每次導航的 GPS 軌跡，讓行程可以重播測試，不必再開一次。這比診斷資料更敏感（會記下你的確切路線），但資料只留在手機上，絕不會上傳。你隨時可以關閉。</string>
    <string name="settings_turn_on">開啟</string>
    <string name="settings_cancel">取消</string>
    <string name="settings_crash_hint">Vela 最近曾意外關閉。傳送當機報告（堆疊追蹤）有助於修正問題。這是純文字檔，不含個人資料。</string>
    <string name="settings_crash_export">匯出當機報告</string>
    <string name="settings_crash_discard">捨棄</string>
    <string name="settings_diag_consent_title">要開啟診斷嗎？</string>
    <string name="settings_diag_consent_body">Vela 會在本機保留簡短記錄，內容包含你的搜尋、路線和任何錯誤。除非你點按「匯出」並選擇傳送對象，否則資料絕不會離開手機。隨時可以關閉以清除記錄。</string>
    <string name="settings_about">關於</string>
    <string name="settings_about_hint">Vela 是去 Google 化的地圖用戶端：底圖使用開放圖磚，地點、路線規劃和路況預估時間擷取自 Google，語音使用 AOSP TextToSpeech。GPLv3 授權，不需要 Play 服務。</string>
    <string name="settings_support">贊助</string>
    <string name="settings_support_hint">Vela 免費且無廣告。如果它對你有幫助，捐款能讓開發持續下去。完全自願。</string>
    <string name="settings_support_button">贊助 Vela</string>
